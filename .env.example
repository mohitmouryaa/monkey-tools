# Defaults para desenvolvimento local (docker compose up -d).
# Copie este arquivo para .env na raiz do monorepo (ele é compartilhado
# entre todos os apps via turbo.json globalEnv).

# --- MongoDB (replica set rs0 — necessário para transações) ---
DATABASE_URL=mongodb://localhost:27017/pdfs-com-br?replicaSet=rs0

# --- Redis (BullMQ + rate limit do proxy.ts) ---
REDIS_URL=redis://localhost:6379

# --- Storage S3-compatible (MinIO local; em prod = DigitalOcean Spaces) ---
DO_SPACES_ENDPOINT=http://localhost:9000
DO_SPACES_ACCESS_KEY=minioadmin
DO_SPACES_SECRET_KEY=minioadmin
DO_SPACES_BUCKET=pdfs-com-br
DO_SPACES_REGION=us-east-1

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
