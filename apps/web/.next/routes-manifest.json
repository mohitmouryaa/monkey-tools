{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...all]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPall": "nxtPall"
      },
      "namedRegex": "^/api/auth/(?<nxtPall>.+?)(?:/)?$"
    },
    {
      "page": "/api/trpc/[trpc]",
      "regex": "^/api/trpc/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtrpc": "nxtPtrpc"
      },
      "namedRegex": "^/api/trpc/(?<nxtPtrpc>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/categories/[id]",
      "regex": "^/dashboard/categories/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/categories/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/pages/custom/[id]",
      "regex": "^/dashboard/pages/custom/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/pages/custom/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/scripts/[id]",
      "regex": "^/dashboard/scripts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/scripts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/tools/[id]",
      "regex": "^/dashboard/tools/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/tools/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tools/[toolCategory]",
      "regex": "^/tools/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoolCategory": "nxtPtoolCategory"
      },
      "namedRegex": "^/tools/(?<nxtPtoolCategory>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tools/[toolCategory]/[tool]",
      "regex": "^/tools/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoolCategory": "nxtPtoolCategory",
        "nxtPtool": "nxtPtool"
      },
      "namedRegex": "^/tools/(?<nxtPtoolCategory>[^/]+?)/(?<nxtPtool>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[slug]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/health",
      "regex": "^/api/health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/health(?:/)?$"
    },
    {
      "page": "/api/upload",
      "regex": "^/api/upload(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/upload(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/categories",
      "regex": "^/dashboard/categories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/categories(?:/)?$"
    },
    {
      "page": "/dashboard/categories/create",
      "regex": "^/dashboard/categories/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/categories/create(?:/)?$"
    },
    {
      "page": "/dashboard/pages",
      "regex": "^/dashboard/pages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/pages(?:/)?$"
    },
    {
      "page": "/dashboard/pages/all-tools",
      "regex": "^/dashboard/pages/all\\-tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/pages/all\\-tools(?:/)?$"
    },
    {
      "page": "/dashboard/pages/custom/create",
      "regex": "^/dashboard/pages/custom/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/pages/custom/create(?:/)?$"
    },
    {
      "page": "/dashboard/pages/homepage",
      "regex": "^/dashboard/pages/homepage(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/pages/homepage(?:/)?$"
    },
    {
      "page": "/dashboard/scripts",
      "regex": "^/dashboard/scripts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/scripts(?:/)?$"
    },
    {
      "page": "/dashboard/scripts/create",
      "regex": "^/dashboard/scripts/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/scripts/create(?:/)?$"
    },
    {
      "page": "/dashboard/tools",
      "regex": "^/dashboard/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/tools(?:/)?$"
    },
    {
      "page": "/dashboard/tools/create",
      "regex": "^/dashboard/tools/create(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/tools/create(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/tools",
      "regex": "^/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tools(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}